# ElevenLabs (used when CUSTOM_TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# ============================================================
# Live-call TTS provider (Twilio custom_ai media stream)
# Pick ONE provider. CUSTOM_TTS_PROVIDER and KIE_TTS_ENABLED MUST agree —
# CUSTOM_TTS_PROVIDER=kie with KIE_TTS_ENABLED=false is a hard config error.
# ------------------------------------------------------------
# Option A: Kie TTS (returns MP3, transcoded to ulaw_8000 via ffmpeg)
CUSTOM_TTS_PROVIDER=kie
KIE_TTS_ENABLED=true
KIE_TTS_MODEL=elevenlabs/text-to-speech-multilingual-v2
KIE_TTS_VOICE=Rachel
KIE_TTS_TIMEOUT_MS=60000
KIE_TTS_POLL_INTERVAL_MS=3000
# Only set if you have CONFIRMED Kie honors it for your model (ElevenLabs models ignore it
# and return audio/mpeg), otherwise leave unset and rely on transcoding.
KIE_TTS_OUTPUT_FORMAT=
#
# Option B: ElevenLabs TTS (returns ulaw_8000 directly, no ffmpeg needed)
# CUSTOM_TTS_PROVIDER=elevenlabs
# KIE_TTS_ENABLED=false
# (set ELEVENLABS_API_KEY and ELEVENLABS_DEFAULT_VOICE_ID above)
# ============================================================
# DEEPGRAM_API_KEY and PUBLIC_MEDIA_WS_URL (above) are required for BOTH providers.

# --- Live-call behavior + debug flags ---
# CUSTOM_AI_MODE=echo makes the agent repeat the caller's exact words back (no LLM/agent).
CUSTOM_AI_MODE=echo
# Set CALL_DEBUG_TRANSCRIPT_ONLY=true to verify STT without triggering TTS/echo.
# The call stays open; only transcripts are logged; "technical issue" is never played.
CALL_DEBUG_TRANSCRIPT_ONLY=false
# Set DEBUG_STT_INTERIM=true to log Deepgram interim (non-final) transcripts.
DEBUG_STT_INTERIM=true
# Set DEBUG_TWILIO_MEDIA_EVENTS=true to log inbound Twilio media frame diagnostics.
DEBUG_TWILIO_MEDIA_EVENTS=true
# Echo the latest interim transcript this many ms after the caller pauses, in case
# Deepgram never emits a final transcript. Defaults to 1500 if unset.
ECHO_INTERIM_AFTER_MS=1500
# Echo the latest interim transcript if the Deepgram socket closes before a final arrives.
ECHO_INTERIM_ON_CLOSE=false

CLIENT_URL=http://localhost:5173
