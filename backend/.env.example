TELEPHONY_SECRET_KEY=
SECRET_ENCRYPTION_KEY=
CARTESIA_API_VERSION=2026-03-01
DOGRAH_CARTESIA_STT_SUPPORTED=true
BACKEND_URL=http://localhost:5000
PUBLIC_BACKEND_URL=https://your-backend-domain.com
PUBLIC_MEDIA_WS_URL=wss://your-backend-domain.com
DOGRAH_API_KEY=
DOGRAH_BASE_URL=https://app.dograh.com/api/v1
DEFAULT_CALLER_ID_NUMBER=+17578297060
DEFAULT_TELEPHONY_PROVIDER=twilio
DEEPGRAM_API_KEY=
DOGRAH_ENABLE_EXTRACTION=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
OPENAI_API_KEY=
IMAGE_PROVIDER=kie
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_CREATE_TASK_ENDPOINT=/api/v1/jobs/createTask
KIE_RECORD_INFO_ENDPOINT=/api/v1/jobs/recordInfo
KIE_IMAGE_MODEL=gpt-image-2-text-to-image
KIE_CALLBACK_URL=https://your-backend-domain.com/api/kie/callback

# ============================================================
# Live-call TTS provider (Twilio custom_ai media stream)
# Pick ONE provider. CUSTOM_TTS_PROVIDER and KIE_TTS_ENABLED MUST agree —
# CUSTOM_TTS_PROVIDER=kie with KIE_TTS_ENABLED=false is a hard config error.
# ------------------------------------------------------------
# Option A: Kie TTS (returns MP3, transcoded to ulaw_8000 via ffmpeg)
CUSTOM_TTS_PROVIDER=kie
KIE_TTS_ENABLED=true
KIE_TTS_MODEL=elevenlabs/text-to-speech-multilingual-v2
KIE_TTS_VOICE=Rachel
KIE_TTS_TIMEOUT_MS=15000
KIE_TTS_POLL_INTERVAL_MS=750
# Only set if you have CONFIRMED Kie honors it for your model; it is ignored by the
# ElevenLabs models (they return audio/mpeg), so leave it unset and rely on transcoding.
KIE_TTS_OUTPUT_FORMAT=
#
# Option B: ElevenLabs TTS (returns ulaw_8000 directly, no ffmpeg needed)
# CUSTOM_TTS_PROVIDER=elevenlabs
# KIE_TTS_ENABLED=false
# (ELEVENLABS_API_KEY and ELEVENLABS_DEFAULT_VOICE_ID above must be set)
# ============================================================
# DEEPGRAM_API_KEY (above) and PUBLIC_MEDIA_WS_URL (above) are required for BOTH providers.

# --- Live-call behavior + debug flags ---
# CUSTOM_AI_MODE=echo makes the agent repeat the caller's exact words back (no LLM/agent).
CUSTOM_AI_MODE=echo
# Set CALL_DEBUG_TRANSCRIPT_ONLY=true to verify STT without triggering TTS/echo.
# The call stays open; only transcripts are logged; "technical issue" is never played.
CALL_DEBUG_TRANSCRIPT_ONLY=false
# Set DEBUG_STT_INTERIM=true to log Deepgram interim (non-final) transcripts.
DEBUG_STT_INTERIM=true
# Set DEBUG_TWILIO_MEDIA_EVENTS=true to log inbound Twilio media frame diagnostics.
DEBUG_TWILIO_MEDIA_EVENTS=true
# Echo the latest interim transcript this many ms after the caller pauses, in case
# Deepgram never emits a final transcript. Defaults to 1000 if unset.
ECHO_INTERIM_AFTER_MS=1000
# Echo the latest interim transcript if the Deepgram socket closes before a final arrives.
ECHO_INTERIM_ON_CLOSE=false

CLIENT_URL=http://localhost:5173
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
FROM_EMAIL=
FROM_NAME=
EMAIL_INBOUND_MODE=imap
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_APP_PASSWORD=
IMAP_POLL_INTERVAL_SECONDS=30
# --- Payments ---
PAYMENT_PROVIDER=razorpay

# Razorpay (get from https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Stripe (only needed if you switch PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx
